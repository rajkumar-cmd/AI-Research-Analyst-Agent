# App
APP_NAME=research-agent-os
APP_ENV=development
LOG_LEVEL=info

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# API
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# Auth
JWT_SECRET_KEY=replace-me-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=false

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=research_agent_os
POSTGRES_USER=research_agent
POSTGRES_PASSWORD=research_agent_password
DATABASE_URL=postgresql+psycopg://research_agent:research_agent_password@postgres:5432/research_agent_os

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_URL=http://chromadb:8000

# AI providers
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Embeddings
EMBEDDING_PROVIDER=mock
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Search providers
SEARCH_PROVIDER=mock
TAVILY_API_KEY=
SERPER_API_KEY=

# Quotas and cost tracking
DEFAULT_DAILY_REQUEST_LIMIT=10
DEFAULT_MONTHLY_REQUEST_LIMIT=100
DEFAULT_MAX_TOKENS_PER_REQUEST=12000
COST_TRACKING_CURRENCY=USD

